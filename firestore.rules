rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // User Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.xp is number && data.level is number && data.streakCount is number;
      }
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == existing().uid;
    }

    // Match Rules (Public read, admin write - simplified for now)
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if false; // System only
    }

    // Prediction Rules
    match /predictions/{predictionId} {
      function isValidPrediction(data) {
        return data.userId == request.auth.uid && isValidId(data.matchId);
      }
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidPrediction(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && (incoming().diff(existing()).affectedKeys().hasOnly(['predictedValue', 'status']));
    }

    // Chat Room Rules
    match /chatRooms/{roomId} {
      function isParticipant() {
        return isSignedIn() && request.auth.uid in resource.data.participants;
      }
      allow read: if isSignedIn() && (resource.data.type == 'public' || isParticipant());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.type == 'public' || isParticipant());

      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/chatRooms/$(roomId)).data.type == 'public' || request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants);
        allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      }
    }

    // Club Rules
    match /clubs/{clubId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || request.auth.uid in existing().members);
    }
  }
}
